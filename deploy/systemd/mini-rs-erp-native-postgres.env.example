# Mini RS ERP native PostgreSQL deployment example.
# Copy to /home/wikki/mini_rs_erp_deploy/.env on Fedora and replace secrets.

MOBILE_API_ADDR=127.0.0.1:18081
RUST_LOG=info
MOBILE_API_LOCAL_STORE_ALLOW_JSON_FALLBACK=0

MINI_ERP_DATABASE_URL=postgres://mini_rs_erp:<password>@127.0.0.1:5432/mini_rs_erp
MINI_ERP_HTTP_TIMEOUT_SECONDS=15
MINI_ERP_DEFAULT_TARGET_WAREHOUSE=
MINI_ERP_DEFAULT_UOM=Kg

MOBILE_API_SESSION_STORE_BACKEND=lmdb
MOBILE_API_SESSION_LMDB_PATH=/home/wikki/mini_rs_erp_deploy/data/mobile_sessions.lmdb
MOBILE_API_SESSION_LMDB_MAP_SIZE_MB=64
MOBILE_API_PROFILE_STORE_BACKEND=lmdb
MOBILE_API_PROFILE_LMDB_PATH=/home/wikki/mini_rs_erp_deploy/data/mobile_profile_prefs.lmdb
MOBILE_API_PROFILE_LMDB_MAP_SIZE_MB=64
MOBILE_API_PUSH_TOKEN_STORE_BACKEND=lmdb
MOBILE_API_PUSH_TOKEN_LMDB_PATH=/home/wikki/mini_rs_erp_deploy/data/mobile_push_tokens.lmdb
MOBILE_API_PUSH_TOKEN_LMDB_MAP_SIZE_MB=64
MOBILE_API_ADMIN_SUPPLIER_STORE_BACKEND=lmdb
MOBILE_API_ADMIN_SUPPLIER_LMDB_PATH=/home/wikki/mini_rs_erp_deploy/data/mobile_admin_suppliers.lmdb
MOBILE_API_ADMIN_SUPPLIER_LMDB_MAP_SIZE_MB=64
MOBILE_API_SESSION_TTL_HOURS=720

MOBILE_DEV_SUPPLIER_PREFIX=10
MOBILE_DEV_WERKA_PREFIX=20
MOBILE_DEV_WERKA_CODE=
MOBILE_DEV_WERKA_NAME=Werka

MINI_RS_GATEWAY_ADDR=0.0.0.0:443
MINI_RS_GATEWAY_UPSTREAM=127.0.0.1:18081
MINI_RS_GATEWAY_UPSTREAM_HOST=127.0.0.1
MINI_RS_GATEWAY_HEALTH_PATH=/healthz
MINI_RS_GATEWAY_CONNECT_TIMEOUT_MS=1000
MINI_RS_GATEWAY_UPSTREAM_TIMEOUT_MS=30000
MINI_RS_GATEWAY_TLS_CERT_PATH=/home/wikki/mini_rs_erp_deploy/tls/fullchain.pem
MINI_RS_GATEWAY_TLS_KEY_PATH=/home/wikki/mini_rs_erp_deploy/tls/privkey.pem
MINI_RS_GATEWAY_METRICS_ADDR=127.0.0.1:19091
